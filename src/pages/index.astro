---
import Layout from '../layouts/Layout.astro';
import Loader from '../components/Loader.astro';
import { loaders } from '../data/loaders';

// The CSS snippets + LLM prompts are emitted as a static /loader-data.json file
// (see loader-data.json.ts) and fetched on demand when the modal first opens,
// so that text stays out of the initial HTML document.

// Cross-promo: the other tools in the Colorion network, surfaced in the header
// dropdown. `?ref=` attributes the referral back to this site.
const REF = 'cssloaders.colorion.co';
const colorionLinks = [
  { label: 'Colorion', href: 'https://www.colorion.co' },
  { label: '2 Color Combinations', href: 'https://2colors.colorion.co' },
  { label: 'Color Palettes', href: 'https://colorpalettes.colorion.co' },
  { label: 'Palette Generator', href: 'https://palettegenerator.colorion.co' },
  { label: 'Material Colors', href: 'https://material.colorion.co' },
  { label: 'Mobile Palette', href: 'https://mobilepalette.colorion.co' },
  { label: 'Gradients', href: 'https://gradients.colorion.co' },
  { label: 'Gradient Buttons', href: 'https://gradientbuttons.colorion.co' },
  { label: 'Animated Buttons', href: 'https://animatedbuttons.colorion.co' },
  { label: 'CSS Tooltips', href: 'https://csstooltips.colorion.co' },
];
---

<Layout>
  <header class="site-header">
    <div class="brand">
      <div class="brand-mark">L</div>
      <span class="mono">CSS Loader Library</span>
    </div>
    <div class="header-right">
      <details class="menu" id="colorion-menu">
        <summary class="menu-trigger mono">
          Colorion Tools
          <span class="menu-caret" aria-hidden="true">▾</span>
        </summary>
        <ul class="menu-list">
          {
            colorionLinks.map((link) => (
              <li>
                <a
                  class="mono"
                  href={`${link.href}?ref=${REF}`}
                  target="_blank"
                  rel="noopener"
                  referrerpolicy="no-referrer-when-downgrade"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
      <div class="header-status mono">
        <span class="pulse-dot"></span>
        {loaders.length} loaders · MIT
      </div>
    </div>
  </header>

  <section class="hero">
    <span class="hero-tag mono">Pure CSS · Copy &amp; paste</span>
    <h1>{loaders.length} <em>CSS loaders</em>,<br />free to copy.</h1>
    <p>
      A library of {loaders.length} loading spinners built with pure CSS — no
      JavaScript, no dependencies. Copy the self-contained <code>CSS</code> for
      any loader, or grab a ready-made <code>Prompt</code> to have your coding
      agent recreate it. Every snippet paints with a single <code>--ink</code>
      colour token and respects <code>prefers-reduced-motion</code>.
    </p>
  </section>

  <main class="library">
    <div class="panel">
      <div class="library-head">
        <span class="mono">Click a loader to copy its CSS or prompt</span>
        <span class="mono">{loaders.length} loaders</span>
      </div>

      <div class="grid" id="loader-grid">
        {
          loaders.map((loader) => (
            <article
              class="cell"
              role="button"
              tabindex="0"
              data-type={loader.type}
              data-name={loader.name}
              data-index={loader.index}
              aria-label={`View CSS for ${loader.name} loader`}
            >
              <span class="cell-index mono">{loader.index}</span>
              <div class="cell-actions">
                <button class="cell-action mono" type="button" data-action="prompt" tabindex="-1" aria-label={`Copy LLM prompt for ${loader.name} loader`}>◳ Prompt</button>
                <button class="cell-action mono" type="button" data-action="css" tabindex="-1" aria-label={`View CSS for ${loader.name} loader`}>⧉ CSS</button>
              </div>
              <div class="stage">
                <Loader type={loader.type} />
              </div>
              <h3>{loader.name}</h3>
            </article>
          ))
        }
      </div>

      <div class="sentinel" id="sentinel" hidden>
        <span class="mono">Loading more loaders…</span>
      </div>
    </div>
  </main>

  <footer class="site-footer">
    <span class="mono">CSS Loader Library</span>
    <nav class="footer-links mono">
      <a href="https://colorion.co?ref=cssloaders.colorion.co" target="_blank" rel="noopener" referrerpolicy="no-referrer-when-downgrade">Colorion</a>
      <a href="https://2colors.colorion.co?ref=cssloaders.colorion.co" target="_blank" rel="noopener" referrerpolicy="no-referrer-when-downgrade">2 Colors</a>
      <a href="https://gradientbuttons.colorion.co?ref=cssloaders.colorion.co" target="_blank" rel="noopener" referrerpolicy="no-referrer-when-downgrade">Gradient Buttons</a>
      <a href="https://animatedbuttons.colorion.co?ref=cssloaders.colorion.co" target="_blank" rel="noopener" referrerpolicy="no-referrer-when-downgrade">Animated Buttons</a>
    </nav>
    <span class="mono">Pure CSS · No dependencies · MIT licensed</span>
  </footer>

  <!-- Copy-to-clipboard modal -->
  <div class="modal-overlay" id="css-modal" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <div class="modal-head">
        <div class="modal-title-group">
          <span class="modal-index mono" id="modal-index"></span>
          <h2 class="modal-title mono" id="modal-title"></h2>
        </div>
        <button class="modal-close mono" id="modal-close" aria-label="Close">✕</button>
      </div>
      <div class="modal-preview">
        <div class="stage" id="modal-preview"></div>
      </div>
      <div class="modal-code-wrap">
        <pre class="modal-code"><code id="modal-code"></code></pre>
      </div>
      <div class="modal-foot">
        <span class="mono modal-hint" id="modal-hint">Pure CSS · self-contained</span>
        <button class="modal-copy mono" id="modal-copy">Copy CSS</button>
      </div>
    </div>
  </div>

</Layout>

<script>
  const BATCH = 12;
  const cells = Array.from(document.querySelectorAll<HTMLElement>('.cell'));
  const sentinel = document.getElementById('sentinel')!;

  // mark lazy mode active so CSS can pause off-screen animations;
  // without JS everything stays visible and animated (progressive enhancement)
  document.documentElement.classList.add('lazy-enabled');

  // pause/resume animations as cells enter and leave the viewport
  const visibility = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        entry.target.classList.toggle('in-view', entry.isIntersecting);
      }
    },
    { rootMargin: '100px' }
  );

  // reveal cells in batches as the sentinel approaches the viewport
  let shown = BATCH;
  cells.slice(BATCH).forEach((cell) => cell.setAttribute('hidden', ''));
  cells.slice(0, BATCH).forEach((cell) => visibility.observe(cell));

  const loadMore = new IntersectionObserver(
    (entries) => {
      if (!entries[0].isIntersecting) return;
      cells.slice(shown, shown + BATCH).forEach((cell) => {
        cell.removeAttribute('hidden');
        visibility.observe(cell);
      });
      shown += BATCH;
      if (shown >= cells.length) {
        loadMore.disconnect();
        sentinel.remove();
      }
    },
    { rootMargin: '300px' }
  );

  if (cells.length > BATCH) {
    sentinel.removeAttribute('hidden');
    loadMore.observe(sentinel);
  }

  // ---------- Copy-to-clipboard modal ----------
  type Mode = 'css' | 'prompt';
  type LoaderData = { snippets: Record<string, string>; prompts: Record<string, string> };

  // The CSS snippets + LLM prompts live in a static JSON file rather than inline,
  // so they don't bloat the document. Fetched once, on first use.
  let dataPromise: Promise<LoaderData> | undefined;
  const loadData = () =>
    (dataPromise ??= fetch('/loader-data.json').then((r) => r.json() as Promise<LoaderData>));

  const MODE_CONFIG: Record<Mode, { key: keyof LoaderData; copyLabel: string; hint: string }> = {
    css: { key: 'snippets', copyLabel: 'Copy CSS', hint: 'Pure CSS · self-contained' },
    prompt: { key: 'prompts', copyLabel: 'Copy prompt', hint: 'LLM prompt · paste into your coding agent' },
  };

  // Warm the cache as soon as the user signals intent (pointer over the grid).
  const grid = document.getElementById('loader-grid');
  grid?.addEventListener('pointerenter', loadData, { once: true });

  const overlay = document.getElementById('css-modal')!;
  const modalIndex = document.getElementById('modal-index')!;
  const modalTitle = document.getElementById('modal-title')!;
  const modalHint = document.getElementById('modal-hint')!;
  const modalPreview = document.getElementById('modal-preview')!;
  const modalCode = document.getElementById('modal-code')!;
  const copyBtn = document.getElementById('modal-copy') as HTMLButtonElement;
  const closeBtn = document.getElementById('modal-close')!;

  let lastFocused: HTMLElement | null = null;
  let copyReset: number | undefined;
  let currentMode: Mode = 'css';
  let currentText = ''; // the copyable text for the open modal ('' while loading)
  let openToken = 0; // guards against races when switching loaders mid-fetch

  async function openModal(cell: HTMLElement, mode: Mode = 'css') {
    const type = cell.dataset.type!;
    const config = MODE_CONFIG[mode];
    const token = ++openToken;

    // Show the modal shell immediately; the code text fills in once data loads.
    currentMode = mode;
    currentText = '';
    modalIndex.textContent = cell.dataset.index || '';
    modalTitle.textContent = cell.dataset.name || '';
    modalHint.textContent = config.hint;
    modalCode.textContent = 'Loading…';

    // clone the live loader for the preview
    const loaderEl = cell.querySelector('.stage > *');
    modalPreview.replaceChildren(loaderEl ? loaderEl.cloneNode(true) : document.createTextNode(''));

    copyBtn.textContent = config.copyLabel;
    copyBtn.classList.remove('copied');

    lastFocused = cell;
    overlay.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    copyBtn.focus();

    let text = '';
    try {
      text = (await loadData())[config.key][type] || '';
    } catch {
      text = '';
    }
    if (token !== openToken) return; // a newer open superseded this one
    currentText = text;
    modalCode.textContent = text || 'Failed to load — please try again.';
  }

  function closeModal() {
    overlay.setAttribute('hidden', '');
    document.body.style.overflow = '';
    modalPreview.replaceChildren();
    lastFocused?.focus();
  }

  async function copyCss() {
    const text = currentText;
    if (!text) return; // data not loaded yet (or failed) — nothing to copy
    try {
      await navigator.clipboard.writeText(text);
    } catch {
      // fallback for non-secure contexts
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      ta.remove();
    }
    copyBtn.textContent = 'Copied ✓';
    copyBtn.classList.add('copied');
    window.clearTimeout(copyReset);
    copyReset = window.setTimeout(() => {
      copyBtn.textContent = MODE_CONFIG[currentMode].copyLabel;
      copyBtn.classList.remove('copied');
    }, 1800);
  }

  cells.forEach((cell) => {
    cell.addEventListener('click', (e) => {
      const action = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
      openModal(cell, action?.dataset.action === 'prompt' ? 'prompt' : 'css');
    });
    cell.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openModal(cell);
      }
    });
  });

  copyBtn.addEventListener('click', copyCss);
  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) closeModal();
  });

  // ---------- Header dropdown (Colorion tools) ----------
  // <details> handles open/close natively; this just closes it when the user
  // clicks away, presses Escape, or picks a destination.
  const menu = document.getElementById('colorion-menu') as HTMLDetailsElement | null;
  if (menu) {
    document.addEventListener('click', (e) => {
      if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.open) menu.open = false;
    });
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => { menu.open = false; })
    );
  }
</script>
